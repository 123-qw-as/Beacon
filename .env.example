# ============================================================
# Beacon Math Agent — 配置文件
# 复制为 .env 并填入实际值后启动：cp .env.example .env
# ============================================================

# --- 前端服务 ---
# 前端 HTTP 服务端口（默认 5173）
PORT=5173
# 后端 CLI 命令（默认通过 uv 调用 Python 包）
MATH_AGENT_COMMAND=uv run math-agent

# --- LLM API ---
# LiteLLM 路由的任何 OpenAI 兼容提供商均可
# 如果你有本地路由器（如 openrouter-proxy），将 BASE 指向它
OPENAI_API_BASE=http://localhost:20128/v1
OPENAI_API_KEY=123456

# --- 模型选择 ---
# 默认模型（用于 coder 等常规节点）
# 格式：provider/model_name，例如 openai/gpt-4o-mini、openai/ds/deepseek-v4-flash
MATH_AGENT_DEFAULT_MODEL=deepseek-v4-flash-free
# coder 可单独路由到更擅长代码、响应更快的模型；缺省继承 DEFAULT_MODEL。
MATH_AGENT_CODER_MODEL=deepseek-v4-flash-free
# 强模型（用于 analyst、modeler、writer、critics 等核心节点）
MATH_AGENT_STRONG_MODEL=deepseek-v4-flash-free
# 图像模型（用于 figure_pipeline 的多模态图表评审与图说生成）
# 需要支持视觉输入的模型；留空或不设则回退到强模型
MATH_AGENT_FIGURE_MODEL=deepseek-v4-flash-free
# coder 最多生成的主/补充图任务数；敏感性图另计。
MATH_AGENT_MAX_FIGURE_TASKS=3
# 主模型遇到超时、连接失败、429 或 5xx 时依次切换；多个模型用英文逗号分隔。
MATH_AGENT_LLM_FALLBACK_MODELS=openai/gemini/gemini-3-flash-preview,openai/ocg/mimo-v2.5-pro

# --- LLM 超时与重试（秒）---
# 旧变量（已弃用，兼容期保留）：解释为 standard.attempt_timeout
MATH_AGENT_LLM_TIMEOUT=300
# 新变量（推荐）：普通调用单次时限 / 总 deadline
MATH_AGENT_LLM_ATTEMPT_TIMEOUT=120
MATH_AGENT_LLM_TOTAL_TIMEOUT=300
# 长文本调用（writer / modeler 主模型）
MATH_AGENT_LLM_LONG_ATTEMPT_TIMEOUT=240
MATH_AGENT_LLM_LONG_TOTAL_TIMEOUT=420
# 代码生成/修复独立档位，避免坏请求占用长文本的 420 秒预算。
MATH_AGENT_LLM_CODE_ATTEMPT_TIMEOUT=90
MATH_AGENT_LLM_CODE_TOTAL_TIMEOUT=240
MATH_AGENT_LLM_CODE_FALLBACK_RESERVE=120
# 为备用模型保留的总 deadline（普通/长文本调用）。
MATH_AGENT_LLM_FALLBACK_RESERVE=120
MATH_AGENT_LLM_LONG_FALLBACK_RESERVE=180
# 备用模型成功后，故障主模型在当前 worker 中的熔断冷却时间。
MATH_AGENT_LLM_MODEL_COOLDOWN=300
# 连续失败的指数冷却上限（默认 30 分钟）。
MATH_AGENT_LLM_MODEL_MAX_COOLDOWN=1800
# worker 进程终止宽限（timeout 后 terminate -> 宽限 -> kill）
MATH_AGENT_LLM_WORKER_KILL_GRACE=2
# 结构化输出 JSON 修复轮次（共享总 deadline）
MATH_AGENT_LLM_VALIDATION_REPAIRS=2

# 旧重试变量（已弃用）：新重试策略按错误类型在代码中硬编码，不从这些变量推导
# MATH_AGENT_LLM_RETRY_ATTEMPTS=5
# MATH_AGENT_LLM_RETRY_BASE_DELAY=2.0
# MATH_AGENT_LLM_RETRY_MAX_DELAY=60.0

MATH_AGENT_EMBED_TIMEOUT=60
MATH_AGENT_MAX_MODEL_ITERATIONS=3
# 论文评审未通过时最多写作/评审轮次；真实竞赛流程建议 3。
MATH_AGENT_MAX_WRITER_ITERATIONS=3
# 生成代码或敏感性脚本执行/输出校验失败后的重试次数。
MATH_AGENT_MAX_CODE_RETRIES=2
# 模型—代码一致性审查轮次（首次 + 最多两次重新生成代码）。
MATH_AGENT_MAX_CODE_VERIFY_ITERATIONS=3
# 单个生成脚本及其子进程树的内存上限（MB）；超限会整树终止并触发代码重试。
MATH_AGENT_CODE_MEMORY_LIMIT_MB=2048
# coder/基线单脚本硬期限（秒）；超时会终止整棵子进程树并进入定向修复。
MATH_AGENT_CODE_TIMEOUT=120
# finalizer 的 completed 最低综合评分；低于此值仍保存产物，但状态为 degraded。
MATH_AGENT_MIN_FINAL_SCORE=7.0
# 竞赛论文正文（不含代码附录）的最低页数与非空白字符数；两项同时用于防止排版或空页注水。
MATH_AGENT_MIN_PAPER_BODY_PAGES=20
MATH_AGENT_MIN_PAPER_BODY_CHARS=15000

# --- RAG（检索增强生成，默认关闭）---
# 设为 1 开启；ingest 后自动从语料库注入相关片段到 prompt
MATH_AGENT_RAG_ENABLED=0
# 向量库路径
MATH_AGENT_RAG_DB=runs/rag.sqlite
# Embedding 模型
MATH_AGENT_RAG_EMBED=text-embedding-3-small
# Embedding 维度
MATH_AGENT_RAG_DIM=1536
# 每个节点检索返回的片段数
MATH_AGENT_RAG_TOPK=4
