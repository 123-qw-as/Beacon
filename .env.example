# ============================================================
# Beacon Math Agent — 配置文件
# 复制为 .env 并填入实际值后启动：cp .env.example .env
# ============================================================

# --- 前端服务 ---
# 前端 HTTP 服务端口（默认 5173）
PORT=5173
# 后端 CLI 命令（默认通过 uv 调用 Python 包）
MATH_AGENT_COMMAND=uv run math-agent

# --- LLM API ---
# LiteLLM 路由的任何 OpenAI 兼容提供商均可
# 如果你有本地路由器（如 openrouter-proxy），将 BASE 指向它
OPENAI_API_BASE=http://localhost:20128/v1
OPENAI_API_KEY=123456

# --- 模型选择 ---
# 默认模型（用于 coder 等常规节点）
# 格式：provider/model_name，例如 openai/gpt-4o-mini、openai/ds/deepseek-v4-flash
MATH_AGENT_DEFAULT_MODEL=deepseek-v4-flash-free
# 强模型（用于 analyst、modeler、writer、critics 等核心节点）
MATH_AGENT_STRONG_MODEL=deepseek-v4-flash-free
# 图像模型（用于 figure_pipeline 的多模态图表评审与图说生成）
# 需要支持视觉输入的模型；留空或不设则回退到强模型
MATH_AGENT_FIGURE_MODEL=deepseek-v4-flash-free

# --- LLM 超时（秒）---
MATH_AGENT_LLM_TIMEOUT=300
MATH_AGENT_EMBED_TIMEOUT=60
MATH_AGENT_MAX_MODEL_ITERATIONS=3

# --- RAG（检索增强生成，默认关闭）---
# 设为 1 开启；ingest 后自动从语料库注入相关片段到 prompt
MATH_AGENT_RAG_ENABLED=0
# 向量库路径
MATH_AGENT_RAG_DB=runs/rag.sqlite
# Embedding 模型
MATH_AGENT_RAG_EMBED=text-embedding-3-small
# Embedding 维度
MATH_AGENT_RAG_DIM=1536
# 每个节点检索返回的片段数
MATH_AGENT_RAG_TOPK=4
